{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScenarioSchema",
  "type": "object",
  "properties": {
    "scenario_id": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "required": [
    "scenario_id",
    "features"
  ]
}